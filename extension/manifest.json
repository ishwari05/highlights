{
  "manifest_version": 3,
  "name": "Highlights",
  "version": "0.5.1",
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "http://127.0.0.1:8000/*",
    "http://localhost:8000/*"
  ],
  "action": {
    "default_popup": "popup/popup.html"
  },
  "web_accessible_resources": [
    {
      "resources": ["styles/panel.css", "styles/highlights.css"],
      "matches": ["<all_urls>"]
    }
  ]
}
